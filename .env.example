# HoloHome AI — environment configuration
# Copy to .env and adjust values

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=30

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=holohome_memory

WHISPER_MODEL=base
TTS_ENGINE=pyttsx3
TTS_RATE=150
TTS_VOLUME=1.0

WAKE_WORD=hey holo
WAKE_WORD_ENGINE=vosk
VOSK_MODEL_PATH=./data/vosk-model-small-en-us-0.15

HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=
MQTT_BROKER=localhost
MQTT_PORT=1883

API_HOST=0.0.0.0
API_PORT=8000

DISPLAY_WIDTH=800
DISPLAY_HEIGHT=600
DISPLAY_FPS=30

LOG_LEVEL=INFO
LOG_FILE=./logs/holohome.log

OFFLINE_FALLBACK_RESPONSE=I'm temporarily offline. Please check that Ollama is running.
